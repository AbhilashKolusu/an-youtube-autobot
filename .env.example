# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Google APIs
GOOGLE_SHEETS_CREDENTIALS_PATH=configs/google_sheets.json
GOOGLE_OAUTH_CLIENT_SECRET=configs/client_secret.json

# YouTube API
YOUTUBE_OAUTH_TOKEN=configs/youtube_oauth.json

# Music AI API
MUSIC_API_KEY=your_music_api_key_here
MUSIC_API_URL=https://api.musicai.com

# Canva API
CANVA_API_TOKEN=your_canva_token_here

# Zapier Webhooks
DISCORD_WEBHOOK_URL=https://hooks.slack.com/...
TWITTER_WEBHOOK_URL=...
INSTAGRAM_WEBHOOK_URL=...
TIKTOK_WEBHOOK_URL=...

# Slack/Email for Reports
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Other
WATCH_FOLDER=recordings/host/
BUILD_FOLDER=builds/
ASSETS_FOLDER=assets/

# Episode settings
EPISODE_LENGTH_MINUTES=5
GENRES=lo-fi,chillhop,synth-wave,ambient