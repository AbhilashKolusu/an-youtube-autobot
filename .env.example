# ═══════════════════════════════════════════════════════════════════════════
# an-youtube-autobot — environment variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM Providers ──────────────────────────────────────────────────────────
# At least one of these is required.
# Anthropic (Claude claude-opus-4-6 manager + Claude Sonnet 4.6 workers) — RECOMMENDED
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI fallback (GPT-4o manager + GPT-4o-mini workers)
OPENAI_API_KEY=sk-...

# ── YouTube (Google OAuth) ─────────────────────────────────────────────────
# Create a project at console.cloud.google.com and enable:
#   YouTube Data API v3, YouTube Analytics API, YouTube Reporting API
YOUTUBE_API_KEY=AIza...                          # Public API key (for search)
YOUTUBE_OAUTH_TOKEN=configs/youtube_oauth.json   # Default OAuth token path

# Per-niche OAuth tokens override the default (created on first run):
#   niches/personal-finance/configs/youtube_oauth.json
#   niches/ai-tools/configs/youtube_oauth.json
#   niches/health-longevity/configs/youtube_oauth.json

# ── ElevenLabs TTS ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...

# Default voice IDs (can be overridden per-niche)
ELEVENLABS_VOICE_FINANCE=21m00Tcm4TlvDq8ikWAM    # Rachel — warm, authoritative
ELEVENLABS_VOICE_AI=ErXwobaYiN019PkySvjV          # Antoni — energetic
ELEVENLABS_VOICE_HEALTH=21m00Tcm4TlvDq8ikWAM     # Rachel

# ── Video Generation ────────────────────────────────────────────────────────
# Pexels (free stock footage for video assembly — 200 req/hour, 20k/month free)
# Get key at: pexels.com/api/
PEXELS_API_KEY=...

# Runway Gen-4 (cinematic hero clips — paid, ~$0.95 per 10s clip)
# Get key at: runwayml.com → Dashboard → API Keys
RUNWAY_API_KEY=...

# ── Thumbnail Generation ────────────────────────────────────────────────────
# Replicate API (runs Flux-schnell for thumbnail image generation)
# Get token at: https://replicate.com/account/api-tokens
# Free tier: ~50 images/month. flux-schnell ~$0.003/image after that.
REPLICATE_API_TOKEN=r8_...

# ── SEO ────────────────────────────────────────────────────────────────────
# No separate API key needed — keyword scoring uses YOUTUBE_API_KEY above.

# ── Web Search ─────────────────────────────────────────────────────────────
# Perplexity AI (real-time web search with citations)
PERPLEXITY_API_KEY=pplx-...

# ── Social Promotion ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Email Reports ───────────────────────────────────────────────────────────
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_USER=abhilashkolusua@gmail.com
EMAIL_PASS=your_app_password
EMAIL_REPORT_TO=you@example.com

# ── Pipeline Settings ───────────────────────────────────────────────────────
# Niches to run when using --all or --schedule
ACTIVE_NICHES=personal-finance,ai-tools,health-longevity,tech-gadgets,travel-tourism,food-cooking

# Daily schedule time (UTC, 24h format)
SCHEDULE_TIME_UTC=06:00

# Content moderation retry limit (1–3)
MOD_MAX_RETRIES=2

# Video upload schedule offset in hours (upload private, publish N hours later)
PUBLISH_DELAY_HOURS=2
